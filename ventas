<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Ventas y Servicios Donzas | Excelencia en soluciones</title>
    <!-- Google Fonts + Font Awesome CDN -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fefcf5;
            color: #1e1e2a;
            scroll-behavior: smooth;
            line-height: 1.5;
        }

        /* variables personalizadas */
        :root {
            --primary: #d44c2f;
            --primary-dark: #b13b21;
            --secondary: #2c3e4e;
            --accent-gold: #e6b422;
            --light-bg: #fffaf2;
            --gray-soft: #f7f3ed;
            --shadow-sm: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.02);
            --shadow-md: 0 20px 25px -12px rgba(0, 0, 0, 0.08);
        }

        /* container general */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* header / navbar */
        .navbar {
            background: white;
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(2px);
            background: rgba(255, 255, 245, 0.96);
        }
        .nav-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            padding: 16px 24px;
            max-width: 1400px;
            margin: 0 auto;
        }
        .logo h1 {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, var(--primary), var(--accent-gold));
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .logo span {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--secondary);
            display: block;
            letter-spacing: 0;
        }
        .nav-links {
            display: flex;
            gap: 2rem;
            align-items: center;
        }
        .nav-links a {
            text-decoration: none;
            font-weight: 600;
            color: #2d3e4b;
            transition: color 0.2s;
        }
        .nav-links a:hover {
            color: var(--primary);
        }
        .btn-nav-contact {
            background-color: var(--primary);
            color: white !important;
            padding: 8px 20px;
            border-radius: 40px;
            transition: all 0.2s;
        }
        .btn-nav-contact:hover {
            background-color: var(--primary-dark);
            transform: scale(0.97);
        }

        /* hero section */
        .hero {
            background: linear-gradient(135deg, #fff5eb 0%, #fde9df 100%);
            padding: 70px 0 80px;
        }
        .hero-grid {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 40px;
        }
        .hero-content {
            flex: 1;
        }
        .hero-badge {
            background: rgba(212, 76, 47, 0.12);
            display: inline-block;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 1rem;
        }
        .hero-content h1 {
            font-size: 3.2rem;
            font-weight: 800;
            line-height: 1.2;
            letter-spacing: -1px;
            color: #1e2a32;
            margin-bottom: 1rem;
        }
        .hero-highlight {
            color: var(--primary);
            border-bottom: 3px solid var(--accent-gold);
        }
        .hero-description {
            font-size: 1.2rem;
            color: #3a4a55;
            margin: 1.5rem 0 2rem;
            max-width: 550px;
        }
        .hero-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
        }
        .btn-primary {
            background: var(--primary);
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.25s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }
        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-3px);
            box-shadow: 0 12px 20px -12px rgba(212,76,47,0.4);
        }
        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 700;
            transition: all 0.2s;
            cursor: pointer;
        }
        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }
        .hero-image {
            flex: 1;
            display: flex;
            justify-content: center;
        }
        .hero-image img {
            max-width: 100%;
            width: 380px;
            filter: drop-shadow(var(--shadow-md));
        }

        /* servicios destacados */
        .section-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 3rem;
            color: #1e2e3a;
        }
        .section-title span {
            color: var(--primary);
        }
        .services {
            padding: 80px 0;
            background: white;
        }
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
        }
        .service-card {
            background: var(--light-bg);
            border-radius: 28px;
            padding: 32px 24px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-sm);
            border: 1px solid #ffede3;
        }
        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-md);
            border-color: #ffd7c9;
        }
        .icon-circle {
            background: #fff0e8;
            width: 80px;
            height: 80px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
        .icon-circle i {
            font-size: 2.5rem;
            color: var(--primary);
        }
        .service-card h3 {
            font-size: 1.6rem;
            margin-bottom: 0.8rem;
        }
        .service-card p {
            color: #4a5b66;
            margin-bottom: 1.5rem;
        }
        .price-tag {
            font-weight: 800;
            font-size: 1.4rem;
            color: var(--primary-dark);
        }

        /* productos destacados / ventas */
        .products {
            background: var(--gray-soft);
            padding: 80px 0;
        }
        .product-slider {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }
        .product-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            transition: all 0.2s;
            box-shadow: 0 5px 16px rgba(0,0,0,0.03);
            border: 1px solid #ffe1d4;
        }
        .product-img {
            background: #f9ede5;
            padding: 32px;
            text-align: center;
        }
        .product-img i {
            font-size: 3.5rem;
            color: var(--primary);
        }
        .product-info {
            padding: 24px;
        }
        .product-info h3 {
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
        }
        .product-desc {
            color: #5e6f7c;
            margin: 8px 0;
            font-size: 0.9rem;
        }
        .product-price {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--secondary);
            margin: 12px 0;
        }
        .btn-buy {
            background: transparent;
            border: 1.5px solid var(--primary);
            color: var(--primary);
            padding: 10px 0;
            width: 100%;
            border-radius: 40px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-buy:hover {
            background: var(--primary);
            color: white;
        }

        /* testimonial */
        .testimonials {
            padding: 80px 0;
            background: #fff9f5;
        }
        .testi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }
        .testi-card {
            background: white;
            padding: 28px;
            border-radius: 32px;
            box-shadow: var(--shadow-sm);
        }
        .testi-card i.fa-quote-left {
            color: var(--accent-gold);
            font-size: 1.8rem;
            opacity: 0.6;
            margin-bottom: 1rem;
        }
        .testi-text {
            font-style: italic;
            margin: 1rem 0;
            color: #2e4459;
        }
        .client-name {
            font-weight: 800;
            margin-top: 1rem;
        }

        /* CTA Final */
        .cta {
            background: linear-gradient(110deg, #2c3e4e, #1f2f3a);
            color: white;
            padding: 70px 0;
            text-align: center;
        }
        .cta h2 {
            font-size: 2.4rem;
            margin-bottom: 1rem;
        }
        .cta p {
            max-width: 600px;
            margin: 0 auto 2rem;
            font-size: 1.1rem;
            opacity: 0.9;
        }
        .cta .btn-primary {
            background: var(--accent-gold);
            color: #1e2a32;
            box-shadow: none;
        }
        .cta .btn-primary:hover {
            background: #f5c542;
            transform: scale(1.02);
        }

        /* footer */
        footer {
            background: #1a262e;
            color: #cddfe6;
            padding: 48px 0 24px;
        }
        .footer-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 32px;
            margin-bottom: 40px;
        }
        .footer-brand h3 {
            font-size: 1.7rem;
            color: white;
        }
        .footer-brand p {
            margin-top: 12px;
            max-width: 260px;
        }
        .footer-links {
            display: flex;
            gap: 4rem;
            flex-wrap: wrap;
        }
        .footer-links a {
            color: #cbdbe2;
            text-decoration: none;
            display: block;
            margin: 8px 0;
            transition: 0.2s;
        }
        .footer-links a:hover {
            color: var(--accent-gold);
        }
        .social i {
            font-size: 1.4rem;
            margin-right: 16px;
            cursor: pointer;
            transition: 0.2s;
        }
        .social i:hover {
            color: var(--accent-gold);
        }
        .copyright {
            text-align: center;
            border-top: 1px solid #2f414d;
            padding-top: 24px;
            font-size: 0.8rem;
        }

        /* modal */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.7);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-content {
            background: white;
            max-width: 480px;
            width: 90%;
            border-radius: 40px;
            padding: 32px;
            text-align: center;
            position: relative;
            animation: fadeUp 0.3s ease;
        }
        @keyframes fadeUp {
            from { transform: translateY(20px); opacity: 0;}
            to { transform: translateY(0); opacity: 1;}
        }
        .modal-content i.fa-check-circle {
            font-size: 3rem;
            color: var(--primary);
            margin-bottom: 1rem;
        }
        .modal-content h3 {
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }
        .close-modal {
            background: var(--primary);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 30px;
            margin-top: 20px;
            cursor: pointer;
            font-weight: bold;
        }
        @media (max-width: 780px) {
            .hero-content h1 { font-size: 2.4rem; }
            .nav-container { flex-direction: column; gap: 12px; }
            .nav-links { flex-wrap: wrap; justify-content: center; gap: 1rem; }
            .section-title { font-size: 1.8rem; }
        }
        button, .btn-buy, .btn-primary, .btn-outline {
            cursor: pointer;
        }
    </style>
</head>
<body>

