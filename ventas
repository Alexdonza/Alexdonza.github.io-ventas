<!-- Modal de Contacto Exitoso -->
<div id="successModal" class="modal">
    <div class="modal-content">
        <i class="fas fa-check-circle"></i>
        <h3>¡Solicitud enviada!</h3>
        <p>Un asesor de Donzas se comunicará contigo en las próximas 24 horas. ¡Gracias por confiar!</p>
        <button class="close-modal" id="closeModalBtn">Cerrar</button>
    </div>
</div>

<script>
    // ---- Productos destacados (base de datos de ventas) ----
    const productsData = [
        { id: 1, name: "Pack Premium Empresarial", description: "Software CRM + Asesoría mensual", price: "$549", icon: "fas fa-chart-pie" },
        { id: 2, name: "Mantenimiento Anual + Soporte 24/7", description: "Respuesta < 30 min, supervisión proactiva", price: "$899/año", icon: "fas fa-shield-alt" },
        { id: 3, name: "Capacitación Ventas Digitales", description: "Curso intensivo + certificación", price: "$249", icon: "fas fa-graduation-cap" },
        { id: 4, name: "Kit Logístico Donzas", description: "Gestión de inventario y envíos exprés", price: "$399/mes", icon: "fas fa-boxes" }
    ];

    function renderProducts() {
        const container = document.getElementById('productsContainer');
        if(!container) return;
        container.innerHTML = '';
        productsData.forEach(prod => {
            const card = document.createElement('div');
            card.className = 'product-card';
            card.innerHTML = `
                <div class="product-img">
                    <i class="${prod.icon}"></i>
                </div>
                <div class="product-info">
                    <h3>${prod.name}</h3>
                    <p class="product-desc">${prod.description}</p>
                    <div class="product-price">${prod.price}</div>
                    <button class="btn-buy" data-product="${prod.name}"><i class="fas fa-shopping-cart"></i> Comprar ahora</button>
                </div>
            `;
            container.appendChild(card);
        });
        // agregar event listeners a los botones de compra
        document.querySelectorAll('.btn-buy').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const productName = btn.getAttribute('data-product') || 'producto Donzas';
                showPurchaseModal(productName);
            });
        });
    }

    // Modal de éxito para compra / contacto
    function showPurchaseModal(productName) {
        const modal = document.getElementById('successModal');
        const modalContentDiv = modal.querySelector('.modal-content');
        // Cambiamos el contenido del modal para simular compra
        modalContentDiv.innerHTML = `
            <i class="fas fa-check-circle"></i>
            <h3>¡Compra exitosa!</h3>
            <p>Has adquirido <strong>${productName}</strong>. En breve recibirás un correo con los detalles de facturación y envío. ¡Gracias por elegir Donzas!</p>
            <button class="close-modal" id="closeModalBtnDynamic">Cerrar</button>
        `;
        modal.style.display = 'flex';
        const closeBtn = document.getElementById('closeModalBtnDynamic');
        if(closeBtn) {
            closeBtn.addEventListener('click', () => {
                modal.style.display = 'none';
                resetModalToDefault();
            });
        }
        // si no, por si ya existe otro
        window.addEventListener('click', (e) => { if(e.target === modal) { modal.style.display = 'none'; resetModalToDefault(); } });
    }

    function resetModalToDefault() {
        const modal = document.getElementById('successModal');
        const modalContentDiv = modal.querySelector('.modal-content');
        // restaurar contenido original del modal
        modalContentDiv.innerHTML = `
            <i class="fas fa-check-circle"></i>
            <h3>¡Solicitud enviada!</h3>
            <p>Un asesor de Donzas se comunicará contigo en las próximas 24 horas. ¡Gracias por confiar!</p>
            <button class="close-modal" id="closeModalBtn">Cerrar</button>
        `;
        const newClose = document.getElementById('closeModalBtn');
        if(newClose) newClose.addEventListener('click', () => { modal.style.display = 'none'; });
    }

    // mostrar el modal para asesoría/contacto genérico
    function showContactModal() {
        const modal = document.getElementById('successModal');
        // aseguramos que tenga la version de contacto
        const modalDiv = modal.querySelector('.modal-content');
        if(modalDiv.innerHTML.indexOf('¡Solicitud enviada!') === -1) {
            modalDiv.innerHTML = `
                <i class="fas fa-check-circle"></i>
                <h3>¡Solicitud enviada!</h3>
                <p>Un asesor de Donzas se comunicará contigo en las próximas 24 horas. ¡Gracias por confiar!</p>
                <button class="close-modal" id="closeModalBtn">Cerrar</button>
            `;
        }
        modal.style.display = 'flex';
        const closeBtn = document.getElementById('closeModalBtn');
        if(closeBtn) {
            closeBtn.addEventListener('click', () => { modal.style.display = 'none'; });
        }
        // si se cierra por fondo
        window.onclick = function(event) {
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        };
    }

    // Navegación suave
    document.querySelectorAll('.nav-links a, .hero-buttons .btn-outline, a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const href = this.getAttribute('href');
            if(href && href.startsWith('#')) {
                e.preventDefault();
                const targetId = href.substring(1);
                const targetElem = document.getElementById(targetId);
                if(targetElem) {
                    targetElem.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        });
    });

    // Botones de apertura de modal
    const heroCta = document.getElementById('heroCtaBtn');
    const ctaModal = document.getElementById('ctaModalBtn');
    const exploreBtn = document.getElementById('exploreBtn');

    if(heroCta) heroCta.addEventListener('click', showContactModal);
    if(ctaModal) ctaModal.addEventListener('click', showContactModal);
    if(exploreBtn) {
        exploreBtn.addEventListener('click', () => {
            document.getElementById('servicios').scrollIntoView({ behavior: 'smooth' });
        });
    }

    // Load products y cerrar modal
    renderProducts();

    // También cerrar modal con X si hiciera falta (evento adicional)
    document.addEventListener('click', (e) => {
        if(e.target.id === 'closeModalBtn' || e.target.classList?.contains('close-modal')) {
            document.getElementById('successModal').style.display = 'none';
        }
    });
    // Para evitar conflictos en botones dinámicos, el reset del modal se encarga al cerrar
    window.addEventListener('load', () => {
        const modalBg = document.getElementById('successModal');
        if(modalBg) {
            modalBg.addEventListener('click', (e) => {
                if(e.target === modalBg) modalBg.style.display = 'none';
            });
        }
    });
</script>
</body>
</html>
